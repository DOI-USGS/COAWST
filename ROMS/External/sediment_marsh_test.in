Qout(idsucr) == F       ! Ucrest_wave             peak wave crest cycle velocity
Qout(idsutr) == F       ! Utroug_wave             peak wave trough cycel velocity
Qout(idstcr) == F       ! Tcrest_wave             wave crest cycle period
Qout(idsttr) == F       ! Ttroug_wave             wave trough cycle period

! Logical switches (TRUE/FALSE) to activate writing of bed bottom sediment
